generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth & Users ─────────────────────────────────────────────

enum UserRole {
  CLIENT
  VENDOR
  ADMIN
}

model User {
  id             String    @id @default(cuid())
  email          String    @unique
  emailVerified  DateTime?
  passwordHash   String?
  name           String
  phone          String?
  avatar         String?
  role           UserRole  @default(CLIENT)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  clientProfile  ClientProfile?
  vendorProfile  VendorProfile?
  accounts       Account[]
  sessions       Session[]
  sentMessages   Message[]      @relation("SentMessages")
  notifications  Notification[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Client ───────────────────────────────────────────────────

model ClientProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  partnerName     String?
  weddingDate     DateTime?
  estimatedBudget Int?
  guestCount      Int?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  weddings   Wedding[]
  budgets    Budget[]
  guestLists GuestList[]
  bookings   Booking[]
  reviews    Review[]
  inquiries  ContactInquiry[]
  moodBoards MoodBoard[]

  @@map("client_profiles")
}

model Wedding {
  id              String        @id @default(cuid())
  clientProfileId String
  name            String
  date            DateTime?
  destinationId   String?
  packageTierId   String?
  status          WeddingStatus @default(PLANNING)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  clientProfile ClientProfile  @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  destination   Destination?   @relation(fields: [destinationId], references: [id])
  packageTier   PackageTier?   @relation(fields: [packageTierId], references: [id])
  days          WeddingDay[]
  events        WeddingEvent[]
  timeline      TimelineItem[]

  @@map("weddings")
}

enum WeddingStatus {
  PLANNING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model WeddingDay {
  id        String   @id @default(cuid())
  weddingId String
  name      String
  date      DateTime?
  notes     String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  wedding Wedding       @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  events  WeddingEvent[]

  @@map("wedding_days")
}

model WeddingEvent {
  id              String   @id @default(cuid())
  weddingId       String
  weddingDayId    String?
  name            String
  eventType       String?
  date            DateTime?
  startTime       String?
  endTime         String?
  venue           String?
  guestCount      Int?
  estimatedBudget Int?
  foodStyle       String?
  foodPreferences String[] @default([])
  menuNotes       String?
  decorStyle      String?
  decorNotes      String?
  attireNotes     String?
  notes           String?
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())

  wedding    Wedding     @relation(fields: [weddingId], references: [id], onDelete: Cascade)
  weddingDay WeddingDay? @relation(fields: [weddingDayId], references: [id], onDelete: SetNull)
  bookings   Booking[]

  @@map("wedding_events")
}

// ─── Vendors ──────────────────────────────────────────────────

model VendorProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  businessName  String
  slug          String   @unique
  categoryId    String
  description   String?
  shortBio      String?
  coverImage    String?
  portfolio     String[] @default([])
  city          String?
  state         String?
  country       String   @default("India")
  experience    Int?
  isVerified    Boolean  @default(false)
  isFeatured    Boolean  @default(false)
  rating        Float    @default(0)
  reviewCount   Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  category       VendorCategory   @relation(fields: [categoryId], references: [id])
  services       VendorService[]
  reviews        Review[]
  bookings       Booking[]
  destinations   VendorDestination[]

  @@map("vendor_profiles")
}

model VendorCategory {
  id          String @id @default(cuid())
  name        String @unique
  slug        String @unique
  description String?
  sortOrder   Int    @default(0)

  vendors VendorProfile[]

  @@map("vendor_categories")
}

model VendorService {
  id              String  @id @default(cuid())
  vendorProfileId String
  name            String
  description     String?
  basePrice       Int
  maxPrice        Int?
  unit            String? // "per event", "per day", "per person"
  isActive        Boolean @default(true)

  vendorProfile VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  bookings      Booking[]

  @@map("vendor_services")
}

model VendorDestination {
  vendorProfileId String
  destinationId   String

  vendorProfile VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  destination   Destination   @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@id([vendorProfileId, destinationId])
  @@map("vendor_destinations")
}

// ─── Destinations & Packages ──────────────────────────────────

model Destination {
  id            String   @id @default(cuid())
  name          String   @unique
  slug          String   @unique
  country       String
  tagline       String?
  description   String?
  heroImage     String?
  gallery       String[] @default([])
  startingPrice Int?
  venueCount    Int      @default(0)
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  weddings Wedding[]
  vendors  VendorDestination[]
  venues   Venue[]

  @@map("destinations")
}

model Venue {
  id            String  @id @default(cuid())
  destinationId String
  name          String
  slug          String  @unique
  description   String?
  address       String?
  capacity      Int?
  priceRange    String?
  heroImage     String?
  gallery       String[] @default([])
  amenities     String[] @default([])
  isActive      Boolean  @default(true)

  destination Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)

  @@map("venues")
}

model PackageTier {
  id            String   @id @default(cuid())
  name          String   @unique
  slug          String   @unique
  tagline       String?
  description   String?
  startingPrice Int
  inclusions    String[] @default([])
  sortOrder     Int      @default(0)
  isActive      Boolean  @default(true)

  weddings Wedding[]

  @@map("package_tiers")
}

// ─── Budget ───────────────────────────────────────────────────

model Budget {
  id              String   @id @default(cuid())
  clientProfileId String
  name            String   @default("My Wedding Budget")
  totalBudget     Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clientProfile ClientProfile    @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  categories    BudgetCategory[]

  @@map("budgets")
}

model BudgetCategory {
  id         String @id @default(cuid())
  budgetId   String
  name       String
  allocated  Int    @default(0)
  sortOrder  Int    @default(0)

  budget Budget       @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  items  BudgetItem[]

  @@map("budget_categories")
}

model BudgetItem {
  id               String  @id @default(cuid())
  budgetCategoryId String
  name             String
  estimatedCost    Int     @default(0)
  actualCost       Int?
  quantity         Int     @default(1)
  isPaid           Boolean @default(false)
  notes            String?
  sortOrder        Int     @default(0)

  budgetCategory BudgetCategory @relation(fields: [budgetCategoryId], references: [id], onDelete: Cascade)

  @@map("budget_items")
}

// ─── Bookings ─────────────────────────────────────────────────

model Booking {
  id              String        @id @default(cuid())
  clientProfileId String
  vendorProfileId String
  vendorServiceId String?
  weddingEventId  String?
  status          BookingStatus @default(INQUIRY)
  eventDate       DateTime?
  totalAmount     Int?
  paidAmount      Int           @default(0)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  clientProfile ClientProfile  @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  vendorProfile VendorProfile  @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  vendorService VendorService? @relation(fields: [vendorServiceId], references: [id])
  weddingEvent  WeddingEvent?  @relation(fields: [weddingEventId], references: [id])
  messages      Message[]

  @@map("bookings")
}

enum BookingStatus {
  INQUIRY
  QUOTE_SENT
  CONFIRMED
  DEPOSIT_PAID
  COMPLETED
  CANCELLED
}

// ─── Reviews ──────────────────────────────────────────────────

model Review {
  id              String   @id @default(cuid())
  clientProfileId String
  vendorProfileId String
  rating          Int
  title           String?
  content         String?
  isPublished     Boolean  @default(false)
  createdAt       DateTime @default(now())

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  vendorProfile VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)

  @@unique([clientProfileId, vendorProfileId])
  @@map("reviews")
}

// ─── Messaging ────────────────────────────────────────────────

model Message {
  id        String   @id @default(cuid())
  senderId  String
  bookingId String
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  sender  User    @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// ─── Notifications ────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

enum NotificationType {
  BOOKING_UPDATE
  MESSAGE
  REVIEW
  PAYMENT
  SYSTEM
}

// ─── Guest Management ─────────────────────────────────────────

model GuestList {
  id              String   @id @default(cuid())
  clientProfileId String
  name            String   @default("Main Guest List")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clientProfile ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  guests        Guest[]

  @@map("guest_lists")
}

model Guest {
  id          String      @id @default(cuid())
  guestListId String
  name        String
  email       String?
  phone       String?
  side        GuestSide   @default(COUPLE)
  rsvpStatus  RsvpStatus  @default(PENDING)
  mealPref    String?
  plusOne      Boolean     @default(false)
  tableNumber Int?
  notes       String?

  guestList GuestList @relation(fields: [guestListId], references: [id], onDelete: Cascade)

  @@map("guests")
}

enum GuestSide {
  BRIDE
  GROOM
  COUPLE
  MUTUAL
}

enum RsvpStatus {
  PENDING
  CONFIRMED
  DECLINED
  MAYBE
}

// ─── Timeline ─────────────────────────────────────────────────

model TimelineItem {
  id          String   @id @default(cuid())
  weddingId   String
  title       String
  description String?
  dueDate     DateTime?
  isCompleted Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  wedding Wedding @relation(fields: [weddingId], references: [id], onDelete: Cascade)

  @@map("timeline_items")
}

// ─── Mood Board ───────────────────────────────────────────────

model MoodBoard {
  id              String   @id @default(cuid())
  clientProfileId String
  name            String   @default("Inspiration")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clientProfile ClientProfile   @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  items         MoodBoardItem[]

  @@map("mood_boards")
}

model MoodBoardItem {
  id          String  @id @default(cuid())
  moodBoardId String
  imageUrl    String
  caption     String?
  sourceUrl   String?
  sortOrder   Int     @default(0)

  moodBoard MoodBoard @relation(fields: [moodBoardId], references: [id], onDelete: Cascade)

  @@map("mood_board_items")
}

// ─── Content ──────────────────────────────────────────────────

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String
  coverImage  String?
  author      String
  tags        String[] @default([])
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("blog_posts")
}

model Testimonial {
  id          String  @id @default(cuid())
  coupleName  String
  destination String
  quote       String
  image       String?
  isPublished Boolean @default(true)
  sortOrder   Int     @default(0)

  @@map("testimonials")
}

model ContactInquiry {
  id              String   @id @default(cuid())
  clientProfileId String?
  name            String
  email           String
  phone           String?
  destination     String?
  weddingDate     String?
  guestCount      String?
  message         String
  status          InquiryStatus @default(NEW)
  createdAt       DateTime      @default(now())

  clientProfile ClientProfile? @relation(fields: [clientProfileId], references: [id])

  @@map("contact_inquiries")
}

enum InquiryStatus {
  NEW
  CONTACTED
  IN_PROGRESS
  CONVERTED
  CLOSED
}
